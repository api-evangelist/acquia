            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{{baseUrl}}/invites/:token",
            "params": [
              {
                "name": "token",
                "value": "",
                "type": "path",
                "description": "The token identifier."
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://accounts.acquia.com/api/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Returns details about an invitation."
        },
