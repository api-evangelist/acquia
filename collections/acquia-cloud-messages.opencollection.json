            "name": "Acquia Dismisses a Message.",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "{{baseUrl}}/messages/:messageUuid/actions/dismiss",
            "params": [
              {
                "name": "messageUuid",
                "value": "da1c0a8e-ff69-45db-88fc-acd6d2affbb7",
                "type": "path",
                "description": "The entity's universally unique identifier."
              }
            ]
          },
          "docs": "Dismisses a message."
        },
